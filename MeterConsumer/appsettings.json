{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "MeterConsumerSettings": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "Username": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "VoltageQueue": "meter_voltage",
      "CurrentQueue": "meter_current",
      "PrefetchCount": 10
    },
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "VoltageTopic": "meter_voltage",
      "CurrentTopic": "meter_current",
      "TopicPartitions": 3,
      "TopicReplicationFactor": 1,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerResetSeconds": 30
    },
    "Fallback": {
      "FilePath": "C:\\ProgramData\\MeterConsumer\\fallback.jsonl",
      "MaxFileSizeBytes": 104857600,
      "ReplayBatchSize": 50,
      "ReplayIntervalSeconds": 10
    },
    "Processing": {
      "MaxConcurrentMessages": 4,
      "InMemoryQueueCapacity": 200
    }
  }
}
